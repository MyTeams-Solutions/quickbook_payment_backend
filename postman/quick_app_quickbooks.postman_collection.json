  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{user_name}}\",\n  \"email\": \"{{user_email}}\",\n  \"user_id\": \"{{user_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "register"
          ]
        },
        "description": "Registers a new user and returns a Sanctum token."
      },
      "response": []
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"user_id\": \"{{user_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "login"
          ]
        },
        "description": "Logs in and returns a Sanctum token."
      },
      "response": []
    },
    {
      "name": "Create Account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"number\": \"{{card_number}}\",\n  \"exp_month\": \"{{exp_month}}\",\n  \"exp_year\": \"{{exp_year}}\",\n  \"cvc\": \"{{cvc}}\",\n  \"name\": \"{{card_name}}\",\n  \"postal_code\": \"{{postal_code}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/accounts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "accounts"
          ]
        },
        "description": "Creates account details for the authenticated user."
      },
      "response": []
    },
    {
      "name": "Get Account By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/accounts/{{account_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{account_id}}"
          ]
        },
        "description": "Gets an account by ID for the authenticated user."
      },
      "response": []
    },
    {
      "name": "QuickBooks Connect",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/qb/connect",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "qb",
            "connect"
          ]
        },
        "description": "Starts OAuth flow and redirects to QuickBooks login."
      },
      "response": []
    },
    {
      "name": "QuickBooks Callback",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/qb/callback?code={{qb_code}}&realmId={{qb_realm_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "qb",
            "callback"
          ],
          "query": [
            {
              "key": "code",
              "value": "{{qb_code}}"
            },
            {
              "key": "realmId",
              "value": "{{qb_realm_id}}"
            }
          ]
        },
        "description": "Handles OAuth callback and stores access/refresh tokens."
      },
      "response": []
    },
    {
      "name": "QuickBooks Charge",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\",\n  \"card_token\": \"{{card_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/qb/charge",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "qb",
            "charge"
          ]
        },
        "description": "Charges a card token via QuickBooks Payments."
      },
      "response": []
    }
  ],
